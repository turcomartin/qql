# .env (gitignored)
QQL_READONLY_PASSWORD=someStrongProdPassword

# LLM — swap provider and model with two variables
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5
#llama3.1:8b
# OLLAMA_BASE_URL: use host.docker.internal when running Ollama natively on the host
# (Apple Silicon Mac or any setup where Ollama isn't a Docker container)
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Switch back to http://ollama:11434 if using the bundled Ollama Docker container

# OpenAI (set LLM_PROVIDER=openai, LLM_MODEL=gpt-4o)
OPENAI_API_KEY=

# AWS Bedrock (set LLM_PROVIDER=bedrock, LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0)
# Auth: set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY, or use IAM role / ~/.aws/credentials
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Google Vertex AI (set LLM_PROVIDER=vertex, LLM_MODEL=gemini-1.5-pro)
# Auth: set GOOGLE_APPLICATION_CREDENTIALS to path of service account JSON, or use ADC
GCP_PROJECT=
GCP_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-key.json

# Backend tuning
MAX_QUERY_ROWS=200
MAX_SQL_RETRIES=3
MAX_CONTEXT_TOKENS=4096
QUERY_TIMEOUT_SECONDS=30
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
